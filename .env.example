# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Postgres
DB_URL=postgresql+psycopg2://<username>:<password>@localhost:5432/<database_name>

# MinIO
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_SIGNATURE_VERSION=s3v4

# Auth
SECRET_KEY=jwt_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
DUMMY_PASS=dummy_password

# Bucket Data
TESTCASE_BUCKET=bytebattles-testcases
SUBMISSION_BUCKET=bytebattles-submission-code

# Container Constants
CONTAINER_POOL_THRESHOLD=10
CONTAINER_WORKER_COUNT=4
MAX_MEMCAP_GB=1
MAX_PIDS=64
ACQUIRE_TIMEOUT_SECONDS=10
WORKSPACE_DIR=/workspace

# Worker Constants
MINIMUM_JUDGE_WORKER=4
MAXIMUM_JUDGE_WORKER=20
JUDGE_WORKER_TIMEOUT=120

# Redis Constants
REDIS_JOB_LIST=judge:queue
REDIS_RESULT_CHANNEL=submission_updates
SHUTDOWN_KEY=control:shutdown
WORKER_PREFIX=worker
WARM_QUEUE_PREFIX=warm
